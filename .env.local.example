# ──────────────────────────────────────────────────
# BoomTrack 환경변수 설정
# 이 파일을 .env.local 로 복사 후 값을 입력하세요
# ──────────────────────────────────────────────────

# OpenWeatherMap API 키 (무료 회원가입)
# https://home.openweathermap.org/users/sign_up
# 무료 티어: 1,000 calls/day — One Call API 3.0 포함
OPENWEATHER_API_KEY=your_openweathermap_key_here
